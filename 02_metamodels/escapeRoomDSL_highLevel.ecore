<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="escapeRoomDSL" nsURI="http://www.example.org/escapeRoomDSL"
    nsPrefix="escapeRoomDSL">
  <eClassifiers xsi:type="ecore:EClass" name="Object">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectID" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="isVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Clue" eSuperTypes="#//Object"/>
  <eClassifiers xsi:type="ecore:EClass" name="Key" eSuperTypes="#//Object"/>
  <eClassifiers xsi:type="ecore:EClass" name="Lock">
    <eStructuralFeatures xsi:type="ecore:EReference" name="door" lowerBound="1" eType="#//Door"
        eOpposite="#//Door/lock"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="associatedKey" lowerBound="1"
        eType="#//Key"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Inventory">
    <eStructuralFeatures xsi:type="ecore:EReference" name="object" upperBound="-1"
        eType="#//Object"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Room">
    <eStructuralFeatures xsi:type="ecore:EReference" name="object" upperBound="-1"
        eType="#//Object"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="puzzle" upperBound="-1"
        eType="#//Puzzle"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="door" lowerBound="1" upperBound="-1"
        eType="#//Door" eOpposite="#//Door/room"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="roomID" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Door">
    <eStructuralFeatures xsi:type="ecore:EReference" name="lock" eType="#//Lock" eOpposite="#//Lock/door"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="room" lowerBound="2" upperBound="2"
        eType="#//Room" eOpposite="#//Room/door"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Puzzle">
    <eStructuralFeatures xsi:type="ecore:EReference" name="inputObjects" upperBound="-1"
        eType="#//Object"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="outputObjects" upperBound="-1"
        eType="#//Object"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="EscapeRoom">
    <eStructuralFeatures xsi:type="ecore:EReference" name="finalVictoryLock" lowerBound="1"
        eType="#//Lock"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="startRoom" lowerBound="1"
        eType="#//Room"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="puzzle" upperBound="-1"
        eType="#//Puzzle" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="room" lowerBound="1" upperBound="-1"
        eType="#//Room" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="lock" lowerBound="1" upperBound="-1"
        eType="#//Lock" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="inventory" lowerBound="1"
        eType="#//Inventory" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="door" lowerBound="1" upperBound="-1"
        eType="#//Door" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="object" lowerBound="1"
        upperBound="-1" eType="#//Object" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="GenericObject" eSuperTypes="#//Object"/>
</ecore:EPackage>
