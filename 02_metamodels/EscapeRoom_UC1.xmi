<?xml version="1.0" encoding="UTF-8"?>
<escapeRoomDSL:EscapeRoom
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:escapeRoomDSL="http://www.example.org/escapeRoomDSL"
    xsi:schemaLocation="http://www.example.org/escapeRoomDSL escapeRoomDSL.ecore"
    finalVictoryLock="//@lock.2"
    startRoom="//@room.1"
    name="UC1 Escape Room"
    description="Example Escape Room">
  <puzzle inputObjects="//@object.0"
      outputObjects="//@object.2"
      name="Symbol Sequence"
      description="Place object in correct order"/>
  <puzzle outputObjects="//@object.1"
      name="Find Matching Book"
      description="Key inside the book"/>
  <room door="//@door.3 //@door.2"
      name="Outside"
      roomID="1"/>
  <room object="//@object.3"
      door="//@door.0 //@door.2"
      name="Entrance"
      roomID="2"/>
  <room object="//@object.1"
      puzzle="//@puzzle.1"
      door="//@door.0 //@door.1"
      name="Reading"
      roomID="3"/>
  <room object="//@object.2 //@object.0"
      puzzle="//@puzzle.0"
      door="//@door.1 //@door.3"
      name="Hidden Study"
      roomID="4"/>
  <lock door="//@door.2"
      name="Entrance Lock"/>
  <lock door="//@door.1"
      associatedKey="//@object.1"
      name="First Lock"/>
  <lock door="//@door.3"
      associatedKey="//@object.2"
      name="Final Lock"/>
  <inventory
      name="Player Inventory"/>
  <door room="//@room.1 //@room.2"
      name="Entrance ↔ Reading"/>
  <door lock="//@lock.1"
      room="//@room.2 //@room.3"
      name="Reading ↔ Hidden Study"/>
  <door lock="//@lock.0"
      room="//@room.0 //@room.1"
      name="Outside ↔ Entrance"/>
  <door lock="//@lock.2"
      room="//@room.0 //@room.3"
      name="Hidden Study ↔ Outside"/>
  <object xsi:type="escapeRoomDSL:GenericObject"
      name="Symbol Tome"
      objectID="5"
      isVisible="true"/>
  <object xsi:type="escapeRoomDSL:Key"
      name="Ancient Key"
      objectID="6"/>
  <object xsi:type="escapeRoomDSL:Key"
      name="Final Key"
      objectID="7"
      isVisible="true"/>
  <object xsi:type="escapeRoomDSL:Clue"
      name="Torn Page"
      objectID="8"
      isVisible="true"/>
</escapeRoomDSL:EscapeRoom>
